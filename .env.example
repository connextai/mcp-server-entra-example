# Copy to .env and adjust.

# --- Microsoft Entra ID (Azure AD) app registration ---
# Application (client) ID of the App Registration that exposes this API. Required.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Directory (tenant) ID — a GUID, or "organizations" / "consumers" / "common". Required.
AZURE_TENANT_ID=11111111-1111-1111-1111-111111111111
# Scope name(s) exactly as defined under "Expose an API" (comma-separated).
AZURE_REQUIRED_SCOPES=access_as_user
# Optional: Application ID URI, if not the default api://<AZURE_CLIENT_ID>.
# AZURE_IDENTIFIER_URI=api://my-api

# --- Server ---
# Public URL the platform uses to reach this server. Every OAuth protected-
# resource metadata value is built from this, so it must be the real, publicly
# reachable URL in production. For local development the default is fine.
PUBLIC_URL=http://localhost:8000

# Where uvicorn binds. Use 0.0.0.0 to accept connections from other machines.
HOST=127.0.0.1
PORT=8000
